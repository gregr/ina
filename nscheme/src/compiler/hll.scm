;;; HLL includes `let*`, `apply/values`, and `case-values` to reduce closure allocation.
;;; HLL includes `late` to support transformations that defer decisions.
;;;;;;;;;;;
;;; HLL ;;;
;;;;;;;;;;;
;; Expr               ::= #(ref          Note Var)
;;                      | #(prim-ref     Note <primop>)
;;                      | #(quote        Note <value>)
;;                      | #(if           Note Expr Expr Expr)
;;                      | #(begin        Note Expr^ Expr)
;;                      | #(call         Note Expr (Expr ...))
;;                      | #(prim-call    Note <primop> (Expr ...))
;;                      | #(case-lambda  Note (Case-lambda-clause ...)
;;                      | #(letrec       Note (Let-binding ...) Expr)
;;                      | #(let*         Note (Let-binding ...) Expr)
;;                      | #(apply/values Note Expr Expr)
;;                      | #(case-values  Note Expr (Case-lambda-clause ...))
;;                      | #(late         Note &Expr)
;; Case-lambda-clause ::= #(Arity Param*~ Expr)
;; Arity              ::= <integer>  ; complemented (negative) if arity is variadic
;; Let-binding        ::= (Param . Expr)
;; &Expr              ::= <box that eventually contains an Expr>
;; Expr^              ::= Expr | (Expr^ . Expr^)
;; Param*~            ::= Param | (Param ...) | (Param Param ... . Param)
;; Param              ::= Var | #f
;; Var                ::= <hllvar>
;; Note               ::= <value>
(define (HLL:ref          note var)         (vector 'ref          note var))
(define (HLL:prim-ref     note p)           (vector 'prim-ref     note p))
(define (HLL:quote        note val)         (vector 'quote        note val))
(define (HLL:if           note c t f)       (vector 'if           note c t f))
(define (HLL:begin        note e^ e)        (vector 'begin        note e^ e))
(define (HLL:call         note rator rand*) (vector 'call         note rator rand*))
(define (HLL:prim-call    note prim rand*)  (vector 'prim-call    note prim rand*))
(define (HLL:case-lambda  note clc*)        (vector 'case-lambda  note clc*))
(define (HLL:letrec       note lb* body)    (vector 'letrec       note lb* body))
(define (HLL:let*         note lb* body)    (vector 'let*         note lb* body))
(define (HLL:apply/values note rator rand)  (vector 'apply/values note rator rand))
(define (HLL:case-values  note rand clc*)   (vector 'case-values  note rand clc*))
(define (HLL:late         note &e)          (vector 'late         note &e))
(define (HLL-note x) (vector-ref x 1))
(define (HLL-note-set x note)
  (case (vector-length x)
    ((3) (vector (vector-ref x 0) note (vector-ref x 2)))
    ((4) (vector (vector-ref x 0) note (vector-ref x 2) (vector-ref x 3)))
    ((5) (vector (vector-ref x 0) note (vector-ref x 2) (vector-ref x 3) (vector-ref x 4)))
    (else (mistake 'HLL-note-set "not HLL" x))))
(define (HLL-annotate x note) (if note (HLL-note-set x note) x))
(define (cl-clause? x)      (and (vector? x) (= (vector-length x) 3)))
(define (cl-clause a p e)   (vector a p e))
(define (cl-clause-arity c) (vector-ref c 0))
(define (cl-clause-param c) (vector-ref c 1))
(define (cl-clause-body  c) (vector-ref c 2))
(define (let-binding? x)    (pair? x))
(define (let-binding p e)   (cons p e))
(define (let-binding-lhs b) (car b))
(define (let-binding-rhs b) (cdr b))

(define-record-type (lambda (v) (list 'hllvar (hllvar-name v))) make-hllvar hllvar?
  (hllvar-name   set-hllvar-name!)
  (hllvar-source set-hllvar-source!)
  (hllvar-data   set-hllvar-data!)
  (hllvar-data2  set-hllvar-data2!))
(define (hllvar name source) (make-hllvar name source #f 0))
(define (hllvar-copy x)
  (make-hllvar (hllvar-name x) (hllvar-source x) (hllvar-data x) (hllvar-refcount x)))
(define hllvar-refcount      hllvar-data2)
(define set-hllvar-refcount! set-hllvar-data2!)
(define (add-hllvar-refcount!    x c) (set-hllvar-refcount! x (+ (hllvar-refcount x) c)))
(define (inc-hllvar-refcount!    x)   (add-hllvar-refcount! x 1))
(define (hllvar-referenced?      x)   (< 0 (hllvar-refcount x)))
(define (hllvar-referenced-once? x)   (= 1 (hllvar-refcount x)))

(define ($cl-clause p e) (cl-clause 0 p e))  ; NOTE: HLL-initialize will compute correct arity
(define (param->arity p) (let loop ((p p) (a 0)) (cond ((null? p) a)
                                                       ((pair? p) (loop (cdr p) (+ a 1)))
                                                       (else      (- (+ a 1))))))
(define (arity+ a inc) (if (< a 0) (- a inc) (+ a inc)))
(define (arity-match? a argc)
  (or (= a argc) (and (arity-variadic? a) (<= (arity-variadic->fixed a) argc))))
(define (arity-variadic?         a) (< a 0))
(define (arity-variadic->fixed   a) (bitwise-not a))
(define (arity-variadic->fixed+1 a) (- a))
(define (arity->arity-mask       a) (if (< a 0) (bitwise-asl -1 (bitwise-not a)) (bitwise-asl 1 a)))
(define (arity-mask-add mask arity) (bitwise-ior (arity->arity-mask arity) mask))
(define (clc*-simplify clc*)
  (let loop ((clc* clc*) (mask 0))
    (if (null? clc*)
        '()
        (let ((clc (car clc*)) (clc* (cdr clc*)))
          (let ((new-mask (arity-mask-add mask (cl-clause-arity clc))))
            (if (= mask new-mask)
                (loop clc* mask)
                (cons clc (loop clc* new-mask))))))))
(define (clc*-sort clc*)  ; NOTE: only valid after clc* has been simplified
  (let loop ((clc* clc*) (fixed* '()) (variadic* '()))
    (if (null? clc*)
        (append fixed* variadic*)
        (let ((clc (car clc*)) (clc* (cdr clc*)))
          (let ((arity (cl-clause-arity clc)))
            (if (arity-variadic? arity)
                (loop clc* fixed* (cons clc variadic*))
                (loop clc* (let insert ((fixed* fixed*))
                             (if (null? fixed*)
                                 (list clc)
                                 (let ((next (car fixed*)))
                                   (if (<= arity (cl-clause-arity next))
                                       (cons clc fixed*)
                                       (cons next (insert (cdr fixed*)))))))
                      variadic*)))))))
(define (clc*-ref/k clc* argc kfail k)
  (let loop ((clc* clc*)) (if (null? clc*)
                              (kfail)
                              (let* ((clc (car clc*)) (clc* (cdr clc*)) (a (cl-clause-arity clc)))
                                (if (arity-match? a argc) (k clc) (loop clc*))))))
(define (param-for-each f p)
  (let loop ((p p)) (cond ((hllvar? p) (f p))
                          ((pair? p)   (let ((x (car p))) (when (hllvar? x) (f x)))
                                       (loop (cdr p)))
                          (else        (values)))))
(define (clc*-map f c*)
  (map (lambda (c) (f (cl-clause-arity c) (cl-clause-param c) (cl-clause-body c))) c*))
(define (clc*-for-each f c*)
  (for-each (lambda (c) (f (cl-clause-arity c) (cl-clause-param c) (cl-clause-body c))) c*))
(define (lb*-map f lb*) (map (lambda (lb) (f (let-binding-lhs lb) (let-binding-rhs lb))) lb*))
(define (lb*-for-each f lb*)
  (for-each (lambda (lb) (f (let-binding-lhs lb) (let-binding-rhs lb))) lb*))

(splicing-let
  ((primop.apply        (procedure->primop apply))
   (primop.values       (procedure->primop values))
   (primop.panic        (procedure->primop panic))
   (primop.make-mvector (procedure->primop make-mvector))
   (primop.mvector-ref  (procedure->primop mvector-ref))
   (primop.mvector-set! (procedure->primop mvector-set!))
   (primop.vector       (procedure->primop vector))
   (primop.cons         (procedure->primop cons))
   (e.0                 (HLL:quote #f 0))
   (e.1                 (HLL:quote #f 1)))
  (define (HLL:make-closure note size)    (HLL:prim-call note primop.make-closure (list size)))
  (define (HLL:closure-ref  note c i)     (HLL:prim-call note primop.closure-ref  (list c i)))
  (define (HLL:closure-set! note c i x)   (HLL:prim-call note primop.closure-set! (list c i x)))
  (define (HLL:closure-call note c rand*) (HLL:prim-call note primop.closure-call (cons c rand*)))
  (define (HLL:apply        note rand*)   (HLL:prim-call note primop.apply rand*))
  (define (HLL:values       note rand*)   (HLL:prim-call note primop.values rand*))
  (define (HLL:panic        note rand*)   (HLL:prim-call note primop.panic rand*))
  (define (HLL:box          note val)     (HLL:prim-call note primop.make-mvector (list e.1 val)))
  (define (HLL:unbox        note b)       (HLL:prim-call note primop.mvector-ref  (list b e.0)))
  (define (HLL:set-box!     note b val)   (HLL:prim-call note primop.mvector-set! (list b e.0 val)))
  (define (HLL:vector       note x*)      (HLL:prim-call note primop.vector       x*))
  (define (HLL:cons         note a d)     (HLL:prim-call note primop.cons         (list a d)))
  (define (HLL:list         note rand*)   (let loop ((note note) (rand* rand*))
                                            (if (null? rand*)
                                                (HLL:quote note '())
                                                (HLL:cons note (car rand*) (loop #f (cdr rand*))))))
  (define (HLL:unsafe-vector-ref note v i) (HLL:prim-call note primop.unsafe-vector-ref (list v i)))
  (define (HLL:unsafe-car        note x)   (HLL:prim-call note primop.unsafe-car        (list x)))
  (define (HLL:unsafe-cdr        note x)   (HLL:prim-call note primop.unsafe-cdr        (list x))))

(splicing-local
  ((define-syntax HLL-case-build
     (syntax-rules (ref prim-ref quote if begin call prim-call case-lambda letrec let* apply/values
                        case-values late)
       ((_ x (((ref a) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* ((ref . (lambda (a) . body)) . v1*) v2* v3*))
       ((_ x (((prim-ref a) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* ((prim-ref . (lambda (a) . body)) . v1*) v2* v3*))
       ((_ x (((quote a) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* ((quote . (lambda (a) . body)) . v1*) v2* v3*))
       ((_ x (((case-lambda a) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* ((case-lambda . (lambda (a) . body)) . v1*) v2* v3*))
       ((_ x (((late a) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* ((late . (lambda (a) . body)) . v1*) v2* v3*))
       ((_ x (((begin a b) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* v1* ((begin . (lambda (a b) . body)) . v2*) v3*))
       ((_ x (((call a b) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* v1* ((call . (lambda (a b) . body)) . v2*) v3*))
       ((_ x (((prim-call a b) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* v1* ((prim-call . (lambda (a b) . body)) . v2*) v3*))
       ((_ x (((letrec a b) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* v1* ((letrec . (lambda (a b) . body)) . v2*) v3*))
       ((_ x (((let* a b) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* v1* ((let* . (lambda (a b) . body)) . v2*) v3*))
       ((_ x (((apply/values a b) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* v1* ((apply/values . (lambda (a b) . body)) . v2*) v3*))
       ((_ x (((case-values a b) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* v1* ((case-values . (lambda (a b) . body)) . v2*) v3*))
       ((_ x (((if a b c) . body) . clause*) v1* v2* v3*)
        (HLL-case-build x clause* v1* v2* ((if . (lambda (a b c) . body)) . v3*)))
       ((_ x (((wrong . a*) . body) . clause*) v1* v2* v3*)
        (HLL-case-unrecognized (wrong . a*)))
       ((_ x () v1* v2* v3*)
        (let ((default (lambda (y) (mistake "no matching HLL-case pattern for expression" y))))
          (HLL-case-finish x default v1* v2* v3*)))
       ((_ x ((y . body)) v1* v2* v3*) (let ((default (lambda (y) . body)))
                                         (HLL-case-finish x default v1* v2* v3*)))))
   (define-syntax (HLL-case-unrecognized stx)
     (syntax-case stx ()
       ((_ pattern) (mistake "invalid HLL-case pattern" (syntax->datum #'pattern)))))
   (define-syntax-rule
     (HLL-case-finish x default ((tag1 . handle1) ...) ((tag2 . handle2) ...) ((tag3 . handle3) ...))
     (case (vector-length x)
       ((3) ((case (vector-ref x 0) ((tag1) handle1) ... (else (lambda (_a) (default x))))
             (vector-ref x 2)))
       ((4) ((case (vector-ref x 0) ((tag2) handle2) ... (else (lambda (_a _b) (default x))))
             (vector-ref x 2) (vector-ref x 3)))
       ((5) ((case (vector-ref x 0) ((tag3) handle3) ... (else (lambda (_a _b _c) (default x))))
             (vector-ref x 2) (vector-ref x 3) (vector-ref x 4)))
       (else (default x)))))
  (define-syntax-rule (HLL-case e . clause*) (let ((x e)) (HLL-case-build x clause* () () ()))))

(splicing-local
  ((define-syntax Expr/note
     (syntax-rules (unquote /note ref prim-ref quote if begin call prim-call case-lambda lambda
                            letrec let* apply/values case-values apply values panic
                            box unbox set-box! cons list)
       ((_ note ,x)                             x)
       ((_ note (ref ,v))                       (HLL:ref note v))
       ((_ note (prim-ref ,p))                  (HLL:prim-ref note p))
       ((_ note (quote ,v))                     (HLL:quote note v))
       ((_ note (quote v))                      (HLL:quote note 'v))
       ((_ note (if c t f))                     (HLL:if note (Expr c) (Expr t) (Expr f)))
       ((_ note (begin e))                      (Expr/note note e))
       ((_ note (begin e e* ...))               (Begin note (Expr e) ((Expr e*) ...)))
       ((_ note (call rator rand* ...))         (HLL:call note (Expr rator) (list (Expr rand*) ...)))
       ((_ note (prim-call ,p rand* ...))       (HLL:prim-call note p (list (Expr rand*) ...)))
       ((_ note (letrec ,lb* body))             (HLL:letrec note lb* (Expr body)))
       ((_ note (let*   ,lb* body))             (HLL:let*   note lb* (Expr body)))
       ((_ note (letrec ((lhs rhs) ...) body))  (HLL:letrec note (list (let-binding lhs (Expr rhs)) ...) (Expr body)))
       ((_ note (let*   ((lhs rhs) ...) body))  (HLL:let*   note (list (let-binding lhs (Expr rhs)) ...) (Expr body)))
       ((_ note (letrec lb* e0 e1 . e*))        (Expr/note note (letrec lb* (begin e0 e1 . e*))))
       ((_ note (let*   lb* e0 e1 . e*))        (Expr/note note (let*   lb* (begin e0 e1 . e*))))
       ((_ note (case-lambda ,clc*))            (HLL:case-lambda note clc*))
       ((_ note (case-lambda (p*~ . body) ...)) (HLL:case-lambda note (list (CL-clause (Param*~ p*~) . body) ...)))
       ((_ note (lambda ,p*~ . body))           (HLL:case-lambda note (list (CL-clause p*~ . body))))
       ((_ note (lambda p*~ . body))            (HLL:case-lambda note (list (CL-clause (Param*~ p*~) . body))))
       ((_ note (apply/values rator rand))      (HLL:apply/values note (Expr rator) (Expr rand)))
       ((_ note (case-values rand ,clc*))       (HLL:case-values note (Expr rand) clc*))
       ((_ old (/note note e))                  (Expr/note note e))
       ((_ note (apply rand* ...))              (HLL:apply note (list (Expr rand*) ...)))
       ((_ note (values rand* ...))             (HLL:values note (list (Expr rand*) ...)))
       ((_ note (panic rand* ...))              (HLL:panic note (list (Expr rand*) ...)))
       ((_ note (box e))                        (HLL:box note (Expr e)))
       ((_ note (unbox b))                      (HLL:unbox note (Expr b)))
       ((_ note (set-box! b e))                 (HLL:set-box! note (Expr b) (Expr e)))
       ((_ note (cons a d))                     (HLL:cons note (Expr a) (Expr d)))
       ((_ note (list rand* ...))               (HLL:list note (list (Expr rand*) ...)))
       ((_ note (rator . rand*))                (HLL:-unrecognized (rator . rand*)))
       ((_ note stx)                            (Atom note stx))))
   (define-syntax CL-clause
     (syntax-rules ()
       ((_ p*~ e0 e1 . e*) (CL-clause p*~ (begin e0 e1 . e*)))
       ((_ p*~ body)       (let ((p p*~)) (cl-clause (param->arity p) p (Expr body))))))
   (define-syntax Param*~
     (syntax-rules ()
       ((_ ())        '())
       ((_ (p . p*~)) (cons p (Param*~ p*~)))
       ((_ p)         p)))
   (define-syntax Begin
     (syntax-rules ()
       ((_ note e^ (e))      (HLL:begin note e^ e))
       ((_ note e^ (e . e*)) (Begin note (cons e^ e) e*))))
   (define-syntax (Atom stx)
     (syntax-case stx ()
       ((_ note stx) (if (identifier? #'stx)
                         #'(HLL:ref note stx)
                         (let ((x (syntax-unwrap #'stx)))
                           (if (or (boolean? x) (number? x) (string? x))
                               #'(HLL:quote note stx)
                               (mistake "invalid HLL: form" #'stx)))))))
   (define-syntax (HLL:-unrecognized stx)
     (syntax-case stx ()
       ((_ e) (mistake "invalid HLL: form" (syntax->datum #'e)))))
   (define-syntax-rule (Expr e) (Expr/note #f e)))
  (define-syntax-rule (HLL: e) (Expr/note #f e)))

(define (HLL-pure? x)
  (HLL-case
    x
    ((ref _) #t) ((prim-ref _) #t) ((quote _) #t) ((case-lambda _) #t)
    ((if c t f) (and (HLL-pure? c) (HLL-pure? t) (HLL-pure? f)))
    ((late &e) (HLL-pure? (unbox &e)))
    ;; TODO: prim-call might also be #t
    (_ #f)))

(define (HLL-initialize P)
  (mdefine old* '())
  (define (restore-old*!) (for-each (lambda (v) (set-hllvar-data! v #f)) old*))
  (define (fail . x*) (restore-old*!) (apply mistake x*))
  (define (fresh/ctx ctx x)
    (when (hllvar-data x) (fail "Var is not unique" x ctx))
    (set! old* (cons x old*))
    (let ((new (hllvar (hllvar-name x) (hllvar-source x))))
      (set-hllvar-data! x new)
      new))
  (define (list?!/ctx ctx x) (unless (list? x) (fail "not a list" x ctx)))
  (define (Param/ctx ctx x) (cond ((not x) x)
                                  ((hllvar? x) (fresh/ctx ctx x))
                                  (else (fail "not a Param" x ctx))))
  (define (Param*~/ctx ctx y) (let loop ((x y))
                                (cond ((null? x) x)
                                      ((pair? x) (cons (Param/ctx ctx (car x)) (loop (cdr x))))
                                      (else (Param/ctx ctx x)))))
  (define (LB*/ctx ctx x*)
    (list?!/ctx ctx x*)
    (map (lambda (x) (let-binding (let-binding-lhs x) (Expr/ctx ctx (let-binding-rhs x))))
         (map (lambda (x)
                (unless (let-binding? x) (fail "not a let binding" x ctx))
                (let-binding (Param/ctx ctx (let-binding-lhs x)) (let-binding-rhs x)))
              x*)))
  (define (CLC*/ctx ctx x*)
    (list?!/ctx ctx x*)
    (map (lambda (x)
           (unless (cl-clause? x) (fail "not a case-lambda clause" x ctx))
           (let ((p (Param*~/ctx ctx (cl-clause-param x))))
             (cl-clause (param->arity p) p (Expr/ctx ctx (cl-clause-body x)))))
         x*))

  (define (Expr/ctx ctx x)
    (define (primop?! p) (unless (primop? p) (fail "not a primop" p x ctx)))
    (unless (and (vector? x) (< 0 (vector-length x))) (fail "invalid HLL" x ctx))
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref v)                   (unless (hllvar? v) (fail "not a Var" v x ctx))
                                 (let ((new (hllvar-data v)))
                                   (unless (hllvar? new) (fail "unbound Var" v x ctx))
                                   (inc-hllvar-refcount! new)
                                   (HLL:ref note new)))
      ((prim-ref p)              (primop?! p) x)
      ((quote val)               x)
      ((if c t f)                (HLL:if note (Expr/ctx x c) (Expr/ctx x t) (Expr/ctx x f)))
      ((begin e^ e)              (HLL:begin note (Expr^/ctx x e^) (Expr/ctx x e)))
      ((call rator rand*)        (HLL:call note (Expr/ctx x rator) (Expr*/ctx x rand*)))
      ((prim-call p rand*)       (primop?! p) (HLL:prim-call note p (Expr*/ctx x rand*)))
      ((case-lambda clc*)        (HLL:case-lambda note (CLC*/ctx x clc*)))
      ((letrec lb* body)         (HLL:letrec note (LB*/ctx ctx lb*) (Expr/ctx x body)))
      ((let* lb* body)           (HLL:let*   note (LB*/ctx ctx lb*) (Expr/ctx x body)))
      ((apply/values rator rand) (HLL:apply/values note (Expr/ctx x rator) (Expr/ctx x rand)))
      ((case-values rand clc*)   (HLL:case-values note (Expr/ctx x rand) (CLC*/ctx x clc*)))
      ((late &e)                 (Expr/ctx ctx (unbox &e)))
      (x                         (fail "not an Expr" x ctx))))
  (define (Expr*/ctx ctx x*) (list?!/ctx ctx x*) (map (lambda (x) (Expr/ctx ctx x)) x*))
  (define (Expr^/ctx ctx x^) (tree-map (lambda (x) (Expr/ctx ctx x)) x^))
  (let ((P (Expr/ctx #f P)))
    (restore-old*!)
    P))

(define (HLL-refresh-refcount! P)
  (define (Param x) (when (hllvar? x) (set-hllvar-refcount! x 0)))
  (define (Param*~ x) (let loop ((x x))
                        (if (pair? x) (begin (Param (car x)) (loop (cdr x))) (Param x))))
  (define (LET* lb* body)
    (lb*-for-each (lambda (lhs _) (Param lhs)) lb*)
    (lb*-for-each (lambda (_ rhs) (Expr rhs)) lb*)
    (Expr body))
  (define (CLC* clc*) (clc*-for-each (lambda (a p body) (Param*~ p) (Expr body)) clc*))
  (define (Expr x)
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref v)                   (inc-hllvar-refcount! v))
      ((prim-ref _)              (values))
      ((quote v)                 (values))
      ((if c t f)                (Expr c) (Expr t) (Expr f))
      ((begin e^ e)              (tree-for-each Expr e^) (Expr e))
      ((call rator rand*)        (Expr rator) (for-each Expr rand*))
      ((prim-call p rand*)       (for-each Expr rand*))
      ((case-lambda clc*)        (CLC* clc*))
      ((letrec lb* body)         (LET* lb* body))
      ((let* lb* body)           (LET* lb* body))
      ((apply/values rator rand) (Expr rator) (Expr rand))
      ((case-values rand clc*)   (Expr rand) (CLC* clc*))
      ((late &e)                 (Expr (unbox &e)))))
  (Expr P))

(define (HLL-copy P)
  (mdefine old* '())
  (define (fresh x)
    (set! old* (cons x old*))
    (let ((new (hllvar-copy x))) (set-hllvar-data! x new) new))
  (define (Param x) (if (hllvar? x) (fresh x) x))
  (define (Param*~ x) (let loop ((x x))
                        (if (pair? x) (cons (Param (car x)) (loop (cdr x))) (Param x))))
  (define (LB* lb*) (lb*-map (lambda (lhs rhs) (let-binding lhs (Expr rhs)))
                             (lb*-map (lambda (lhs rhs) (let-binding (Param lhs) rhs)) lb*)))
  (define (CLC* clc*) (clc*-map (lambda (a p body) (cl-clause a (Param*~ p) (Expr body))) clc*))
  (define (Expr x)
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref v)                   (HLL:ref note (hllvar-data v)))
      ((prim-ref _)              x)
      ((quote v)                 x)
      ((if c t f)                (HLL:if note (Expr c) (Expr t) (Expr f)))
      ((begin e^ e)              (HLL:begin note (tree-map Expr e^) (Expr e)))
      ((call rator rand*)        (HLL:call note (Expr rator) (map Expr rand*)))
      ((prim-call p rand*)       (HLL:prim-call note p (map Expr rand*)))
      ((case-lambda clc*)        (HLL:case-lambda note (CLC* clc*)))
      ((letrec lb* body)         (HLL:letrec note (LB* lb*) (Expr body)))
      ((let* lb* body)           (HLL:let*   note (LB* lb*) (Expr body)))
      ((apply/values rator rand) (HLL:apply/values note (Expr rator) (Expr rand)))
      ((case-values rand clc*)   (HLL:case-values note (Expr rand) (CLC* clc*)))
      ((late &e)                 (Expr (unbox &e)))))
  (let ((P (Expr P)))
    (for-each (lambda (v) (set-hllvar-data! v (hllvar-data (hllvar-data v)))) old*)
    P))

(define (HLL-for-each-variable f P)
  (define (Param x) (when (hllvar? x) (f x)))
  (define (Param*~ x) (let loop ((x x))
                        (if (pair? x) (begin (Param (car x)) (loop (cdr x))) (Param x))))
  (define (LB* lb*) (lb*-for-each (lambda (lhs rhs) (Param lhs) (Expr rhs)) lb*))
  (define (CLC* clc*) (clc*-for-each (lambda (a p body) (Param*~ p) (Expr body)) clc*))
  (define (Expr x)
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref _)                   (values))
      ((prim-ref _)              (values))
      ((quote _)                 (values))
      ((if c t f)                (Expr c) (Expr t) (Expr f))
      ((begin e^ e)              (tree-for-each Expr e^) (Expr e))
      ((call rator rand*)        (Expr rator) (for-each Expr rand*))
      ((prim-call p rand*)       (for-each Expr rand*))
      ((case-lambda clc*)        (CLC* clc*))
      ((letrec lb* body)         (LB* lb*) (Expr body))
      ((let* lb* body)           (LB* lb*) (Expr body))
      ((apply/values rator rand) (Expr rator) (Expr rand))
      ((case-values rand clc*)   (Expr rand) (CLC* clc*))
      ((late &e)                 (Expr (unbox &e)))))
  (Expr P))

(define (HLL-variable* P)
  (mdefine var* '())
  (HLL-for-each-variable (lambda (x) (set! var* (cons x var*))) P)
  var*)

(define (HLL-pretty P)
  (define (param-pretty x) (if x (hllvar-name x) #t))
  (define (lb*-pretty lb*) (map (lambda (lb) (list (param-pretty (let-binding-lhs lb))
                                                   (loop (let-binding-rhs lb))))
                                lb*))
  (define (clc*-pretty clc*) (map (lambda (clc) (list (improper-list-map param-pretty
                                                                         (cl-clause-param clc))
                                                      (loop (cl-clause-body clc))))
                                  clc*))
  (define (loop x)
    (HLL-case
      x
      ((ref v)                   (list 'ref (param-pretty v)))
      ((prim-ref p)              (list 'primop (primop-name p)))
      ((quote val)               (list 'quote val))
      ((if c t f)                (list 'if (loop c) (loop t) (loop f)))
      ((begin e^ e)              (cons 'begin (tree-map-flatten loop e^ (list (loop e)))))
      ((call rator rand*)        (cons* 'call (loop rator) (map loop rand*)))
      ((prim-call p rand*)       (cons* 'prim-call (primop-name p) (map loop rand*)))
      ((case-lambda clc*)        (cons 'case-lambda (clc*-pretty clc*)))
      ((letrec lb* body)         (list 'letrec (lb*-pretty lb*) (loop body)))
      ((let* lb* body)           (list 'let*   (lb*-pretty lb*) (loop body)))
      ((apply/values rator rand) (list 'apply/values (loop rator) (loop rand)))
      ((case-values rand clc*)   (cons* 'case-values (loop rand) (clc*-pretty clc*)))
      ((late &e)                 (loop (unbox &e)))))
  (loop P))

(define (make-hllvar-rename!)
  (mlet ((uid 0))
    (lambda (x)
      (let ((uid.current uid))
        (set! uid (+ uid 1))
        (set-hllvar-name! x (string->symbol (string-append (symbol->string (or (hllvar-name x) '_))
                                                           "." (number->string uid.current))))))))

(define (HLL-distinguish-variable-names! P) (HLL-for-each-variable (make-hllvar-rename!) P))
(define (HLL-pretty-uid P)
  (let ((P (HLL-copy P))) (HLL-distinguish-variable-names! P) (HLL-pretty P)))

(define (HLL-check-letrec P)
  (mdefine var*.all '())
  (mdefine bnd*.pending '())
  (define (bind! v initialized? init-var)
    (let ((bnd (mvector initialized? init-var '())))
      (set-hllvar-data! v bnd)
      (set! bnd*.pending (cons bnd bnd*.pending)))
    (set! var*.all (cons v var*.all)))
  (define (bind-nonrec! v) (bind! v #t #f))
  (define (bind-rec!    v) (bind! v #f (hllvar 'init? #f)))
  (define (binding-initialized? x)   (mvector-ref x 0))
  (define (binding-init-var     x)   (mvector-ref x 1))
  (define (binding-initialize!  x)   (mvector-set! x 0 #t))
  (define (binding-defer!       x t) (mvector-set! x 2 (cons t (mvector-ref x 2))))
  (define (binding-force!       x)   (let ((t* (mvector-ref x 2)))
                                       (mvector-set! x 2 '())
                                       (for-each (lambda (t) (t)) t*)))
  (define (Expr/no-escape x) (Expr/binding #f #f x))
  (define (Expr/binding outer-bnd escape? x)
    (define (loop x) (Expr/binding outer-bnd escape? x))
    (define (Expr x) (Expr/binding outer-bnd #t x))
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref v)
       (let ((bnd (hllvar-data v)))
         (if bnd
             (let ((x (if (binding-initialized? bnd)
                          x
                          (HLL: (if ,(let ((init (binding-init-var bnd)))
                                       (inc-hllvar-refcount! init)
                                       (HLL: (unbox init)))
                                    ,x
                                    (/note note (panic #f "referenced uninitialized variable"
                                                       ',(hllvar-name v))))))))
               (if escape?
                   (binding-force! bnd)
                   (when outer-bnd (binding-defer! outer-bnd (lambda () (binding-force! bnd)))))
               x)
             x)))
      ((prim-ref _)        x)
      ((quote _)           x)
      ((if c t f)          (HLL:if note (Expr/no-escape c) (loop t) (loop f)))
      ((begin e^ e)        (HLL:begin note (tree-map Expr/no-escape e^) (loop e)))
      ((call rator rand*)  (HLL:call note (Expr rator) (map Expr rand*)))
      ((prim-call p rand*) (HLL:prim-call note p (map Expr rand*)))
      ((case-lambda clc*)
       (define (^expr)
         (HLL:case-lambda note (clc*-map (lambda (a p body) (cl-clause a p (Expr body))) clc*)))
       (cond (escape?   (^expr))
             (outer-bnd (let ((&expr (box #f)))
                          (binding-defer! outer-bnd (lambda () (set-box! &expr (^expr))))
                          (HLL:late #f &expr)))
             (else      (HLL:quote note #t))))
      ((letrec lb* body)
       (lb*-for-each (lambda (lhs _) (when lhs (bind-rec! lhs))) lb*)
       (mdefine init* '())
       (let* ((x (HLL:letrec
                   note
                   (lb*-map
                     (lambda (lhs rhs)
                       (let-binding
                         lhs
                         (if lhs
                             (let* ((bnd (hllvar-data lhs))
                                    (init (binding-init-var bnd))
                                    (rhs (Expr/binding bnd #f rhs)))
                               (binding-initialize! bnd)
                               (if (hllvar-referenced? init)
                                   (let ((rhsvar (hllvar #f #f)))
                                     (inc-hllvar-refcount! init)
                                     (inc-hllvar-refcount! rhsvar)
                                     (set! init* (cons init init*))
                                     (HLL: (let* ((rhsvar ,rhs)) (set-box! init #t) rhsvar)))
                                   rhs))
                             (Expr/no-escape rhs))))
                     lb*)
                   (loop body)))
              (init* init*))
         (if (null? init*)
             x
             (HLL: (let* ,(map (lambda (init) (let-binding init (HLL: (box #f)))) init*) ,x)))))
      ((let* lb* body)
       (lb*-for-each (lambda (lhs _) (when lhs (bind-nonrec! lhs))) lb*)
       (HLL:let* note (lb*-map (lambda (lhs rhs)
                                 (let-binding lhs (Expr/binding (and lhs (hllvar-data lhs)) #f rhs)))
                               lb*)
                 (loop body)))
      ((apply/values rator rand) (HLL:apply/values note (Expr rator) (Expr rand)))
      ((case-values rand clc*)   (define (CLC a p body) (cl-clause a p (loop body)))
                                 (HLL:case-values note (Expr rand) (clc*-map CLC clc*)))
      ((late &e)                 (loop (unbox &e)))))
  (let ((topvar (hllvar #f #f)))
    (bind-nonrec! topvar)
    (let ((P (Expr/binding (hllvar-data topvar) #f P)))
      (let loop () (let ((bnd* bnd*.pending))
                     (set! bnd*.pending '())
                     (unless (null? bnd*) (for-each binding-force! bnd*) (loop))))
      (for-each (lambda (x) (set-hllvar-data! x #f)) var*.all)
      P)))

;; HLL-bind-known-lambda may disconnect mutual recursion, so run it before HLL-stratify-letrec.
(define (HLL-bind-known-lambda P)
  (define (make-cldc clc) (mvector #f #f clc))
  (define (cldc-lhs   cldc) (mvector-ref cldc 0))
  (define (cldc-seen? cldc) (mvector-ref cldc 1))
  (define (cldc-clc   cldc) (mvector-ref cldc 2))
  (define (set-cldc-lhs! cldc lhs) (mvector-set! cldc 0 lhs))
  (define (set-cldc-clc! cldc clc) (mvector-set! cldc 2 clc))
  (define (cldc-see!     cldc)     (mvector-set! cldc 1 #t))
  (define (cldc-Expr-clc! cldc) (unless (cldc-seen? cldc)
                                  (cldc-see! cldc)
                                  (set-cldc-clc! cldc (CLC (cldc-clc cldc)))))
  (define (cldc-known cldc) (let ((clc (cldc-clc cldc)))
                              (if (arity-variadic? (cl-clause-arity clc))
                                  (cl-clause (arity-variadic->fixed+1 (cl-clause-arity clc))
                                             (improper-list->list (cl-clause-param clc))
                                             (cl-clause-body clc))
                                  clc)))
  (define (cldc-unknown cldc)
    (let ((lhs (cldc-lhs cldc)) (clc (cldc-clc cldc)))
      (if lhs
          (let ((a (cl-clause-arity clc)) (p*~ (cl-clause-param clc)))
            (cl-clause a p*~ (HLL:call #f (HLL:ref #f lhs)
                                       (map (lambda (p) (if p (HLL:ref #f p) (HLL:quote #f #t)))
                                            (if (arity-variadic? a)
                                                (improper-list->list p*~)
                                                p*~)))))
          clc)))
  (define (cldc-call cldc lhs note rator rand*)
    (let ((argc (length rand*)) (arity (cl-clause-arity (cldc-clc cldc))))
      (and (arity-match? arity argc)
           (HLL:call note
                     (HLL:ref (HLL-note rator)
                              (or (cldc-lhs cldc)
                                  (let ((lhs (hllvar (hllvar-name lhs) (hllvar-source lhs))))
                                    (set-cldc-lhs! cldc lhs)
                                    (cldc-Expr-clc! cldc)
                                    lhs)))
                     (if (arity-variadic? arity)
                         (let loop ((count (arity-variadic->fixed arity)) (rand* rand*))
                           (if (< 0 count)
                               (cons (car rand*) (loop (- count 1) (cdr rand*)))
                               (list (HLL:list #f rand*))))
                         rand*)))))
  (define (make-cld lhs note clc*) (mvector lhs note (map make-cldc clc*) #f))
  (define (cld-lhs     cld) (mvector-ref cld 0))
  (define (cld-note    cld) (mvector-ref cld 1))
  (define (cld-cldc*   cld) (mvector-ref cld 2))
  (define (cld-escape? cld) (mvector-ref cld 3))
  (define (cld-call cld note rator rand*)
    (let ((lhs (cld-lhs cld)))
      (or (ormap (lambda (cldc) (cldc-call cldc lhs note rator rand*)) (cld-cldc* cld))
          (begin (cld-escape! cld) (HLL:call note rator rand*)))))
  (define (cld-escape! cld) (unless (mvector-ref cld 3)
                              (mvector-set! cld 3 #t)
                              (for-each cldc-Expr-clc! (cld-cldc* cld))))
  (define (cld-known* cld)
    (let loop ((cldc* (cld-cldc* cld)))
      (if (null? cldc*)
          '()
          (let* ((cldc (car cldc*)) (lb* (loop (cdr cldc*))) (lhs (cldc-lhs cldc)))
            (if lhs
                (cons (let-binding lhs (HLL:case-lambda #f (list (cldc-known cldc)))) lb*)
                lb*)))))
  (define (cld-unknown cld)
    (and (cld-escape? cld) (HLL:case-lambda (cld-note cld) (map cldc-unknown (cld-cldc* cld)))))
  (define (lb*-register lb*)
    (let loop ((lb* lb*))
      (if (null? lb*)
          '()
          (let* ((lb (car lb*)) (lhs*.cl (loop (cdr lb*))) (lhs (let-binding-lhs lb)))
            (define (rhs->cld rhs)
              (HLL-case rhs
                        ((case-lambda clc*)
                         (and (pair? clc*) (or (pair? (cdr clc*))
                                               (arity-variadic? (cl-clause-arity (car clc*))))
                              (make-cld lhs (HLL-note rhs) clc*)))
                        ((late &e) (rhs->cld (unbox &e)))
                        (_         #f)))
            (let ((cld (and lhs (rhs->cld (let-binding-rhs lb)))))
              (if cld (begin (set-hllvar-data! lhs cld) (cons lhs lhs*.cl)) lhs*.cl))))))
  (define (CLC clc)
    (cl-clause (cl-clause-arity clc) (cl-clause-param clc) (Expr (cl-clause-body clc))))
  (define (CLC* clc*) (map CLC clc*))
  (define (Expr x)
    (define note (HLL-note x))
    (define (Let make-let lb* body)
      (let* ((lhs*.cl (lb*-register lb*))
             (lb* (lb*-map (lambda (l r) (let-binding l (if (and l (hllvar-data l)) r (Expr r))))
                           lb*))
             (body (Expr body))
             (lb* (let loop ((lb* lb*))
                    (if (null? lb*)
                        '()
                        (let ((lb (car lb*)) (lb* (loop (cdr lb*))))
                          (let* ((lhs (let-binding-lhs lb)) (cld (and lhs (hllvar-data lhs))))
                            (if cld
                                (append (cld-known* cld)
                                        (let ((unknown (cld-unknown cld)))
                                          (if unknown (cons (let-binding lhs unknown) lb*) lb*)))
                                (cons lb lb*))))))))
        (for-each (lambda (lhs) (set-hllvar-data! lhs #f)) lhs*.cl)
        (make-let note lb* body)))
    (HLL-case
      x
      ((ref v)      (let ((cld (hllvar-data v))) (when cld (cld-escape! cld))) x)
      ((prim-ref _) x)
      ((quote _)    x)
      ((if c t f)   (HLL:if note (Expr c) (Expr t) (Expr f)))
      ((begin e^ e) (HLL:begin note (tree-map Expr e^) (Expr e)))
      ((call rator rand*)
       (define (default) (HLL:call note (Expr rator) (map Expr rand*)))
       (let retry ((rator rator))
         (HLL-case
           rator
           ((ref v) (let ((cld (hllvar-data v)))
                      (if cld (cld-call cld note rator (map Expr rand*)) (default))))
           ((late &e) (retry (unbox &e)))
           (_ (default)))))
      ((prim-call p rand*)       (HLL:prim-call note p (map Expr rand*)))
      ((case-lambda clc*)        (HLL:case-lambda note (CLC* clc*)))
      ((letrec lb* body)         (Let HLL:letrec lb* body))
      ((let*   lb* body)         (Let HLL:let* lb* body))
      ((apply/values rator rand) (HLL:apply/values note (Expr rator) (Expr rand)))
      ((case-values rand clc*)   (HLL:case-values note (Expr rand) (CLC* clc*)))
      ((late &e)                 (Expr (unbox &e)))))
  (Expr P))

;; HLL-stratify-letrec is an optional pass that is intended to be run before HLL-convert-letrec so
;; that fewer bindings are converted to boxes.  This pass may also speed up HLL-sink-join-points.
;; If HLL-check-letrec is run, it should be run before HLL-stratify-letrec because the latter may
;; reorder bindings in a way that masks issues with the original initialization order.
;; See these related publications:
;; https://web.archive.org/web/20241217023225/https://legacy.cs.indiana.edu/~dyb/pubs/fixing-letrec.pdf
;; https://web.archive.org/web/20240113151850/https://legacy.cs.indiana.edu/~dyb/pubs/letrec-reloaded.pdf
(define (HLL-stratify-letrec P)
  (define (make-node lhs rhs cl? &active-src) (mvector lhs rhs cl? '() &active-src #f))
  (define (node-lhs         n) (mvector-ref n 0))
  (define (node-rhs         n) (mvector-ref n 1))
  (define (node-cl?         n) (mvector-ref n 2))
  (define (node-edge*       n) (mvector-ref n 3))
  (define (node-&active-src n) (mvector-ref n 4))  ; phase 1 (graph construction)
  (define (node-recent-src  n) (mvector-ref n 5))  ; phase 1
  (define (set-node-rhs!         n r) (mvector-set! n 1 r))
  (define (set-node-recent-src!  n x) (mvector-set! n 5 x))  ; phase 1
  (define (node-link!            n m) (mvector-set! n 3 (cons m (node-edge* n))))
  (define (node-active-src-link! n)   (let ((src (unbox (node-&active-src n))))
                                        (unless (eqv? (node-recent-src n) src)
                                          (set-node-recent-src! n src)
                                          (node-link! src n))))
  (define (node-visit-index n) (mvector-ref n 4))  ; phase 2 (SCC topological sort)
  (define (node-scc-index   n) (mvector-ref n 5))  ; phase 2
  (define (set-node-visit-index! n vi) (mvector-set! n 4 vi))  ; phase 2
  (define (set-node-scc-index!   n si) (mvector-set! n 5 si))  ; phase 2
  (define (CLC* clc*) (clc*-map (lambda (a p body) (cl-clause a p (Expr body))) clc*))
  (define (Expr x)
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref v)             (let ((n (hllvar-data v))) (when n (node-active-src-link! n))) x)
      ((prim-ref _)        x)
      ((quote v)           x)
      ((if c t f)          (HLL:if note (Expr c) (Expr t) (Expr f)))
      ((begin e^ e)        (HLL:begin note (tree-map Expr e^) (Expr e)))
      ((call rator rand*)  (HLL:call note (Expr rator) (map Expr rand*)))
      ((prim-call p rand*) (HLL:prim-call note p (map Expr rand*)))
      ((case-lambda clc*)  (HLL:case-lambda note (CLC* clc*)))
      ((letrec lb* body)
       (define &active-src (box #f))
       (define (node-Expr-rhs! n) (set-box! &active-src n) (set-node-rhs! n (Expr (node-rhs n))))
       (define (stratify node node*)
         (for-each (lambda (n)
                     (let ((lhs (node-lhs n))) (when lhs (set-hllvar-data! lhs #f)))
                     (set-node-visit-index! n #f)
                     (set-node-scc-index! n #f))
                   (cons node node*))
         (let loop ((node node) (node* node*))
           (if (HLL-pure? (node-rhs node))
               (unless (null? node*) (loop (car node*) (cdr node*)))
               (let loop ((impure node) (node* node*))
                 (unless (null? node*)
                   (let ((node (car node*)) (node* (cdr node*)))
                     (if (HLL-pure? (node-rhs node))
                         (loop impure node*)
                         (begin (node-link! node impure) (loop node node*))))))))
         (mlet ((vi 0) (si 0))
           (define (make-scc root-index node^) (cons root-index node^))
           (define (scc-root-index scc) (car scc))
           (define (scc-node^      scc) (cdr scc))
           (define (scc-unite a b) (make-scc (min (scc-root-index a) (scc-root-index b))
                                             (cons (scc-node^ a) (scc-node^ b))))
           (define (scc-raise scc root-index) (if (< root-index (scc-root-index scc))
                                                  (make-scc root-index (scc-node^ scc))
                                                  scc))
           (define (finish-scc! scc)
             (let ((si.current si))
               (set! si (+ si.current 1))
               (let loop ((n^ (scc-node^ scc)))
                 (if (pair? n^)
                     (begin (loop (car n^)) (loop (cdr n^)))
                     (set-node-scc-index! n^ si.current)))))
           (define (node-finished? n) (node-scc-index n))
           (define (node-visited? n) (node-visit-index n))
           (define (node-visit! n)
             (unless (node-visited? n)
               (let visit ((n n))
                 (let ((vi.current vi))
                   (set-node-visit-index! n vi.current)
                   (set! vi (+ vi.current 1))
                   (let loop ((n* (node-edge* n)) (scc (make-scc vi.current n)))
                     (cond ((not (null? n*))
                            (let ((n (car n*)))
                              (loop (cdr n*) (cond ((not (node-visited? n))
                                                    (let ((scc? (visit n)))
                                                      (if scc? (scc-unite scc scc?) scc)))
                                                   ((node-finished? n) scc)
                                                   (else (scc-raise scc (node-visit-index n)))))))
                           ((< (scc-root-index scc) vi.current) scc)
                           (else (finish-scc! scc) #f)))))))
           (node-visit! node)
           (for-each node-visit! node*)
           (let* ((slen si) (scc* (make-mvector slen '())))
             (let loop ((node node) (node* node*))
               (let ((si (node-scc-index node)))
                 (mvector-set! scc* si (cons node (mvector-ref scc* si))))
               (unless (null? node*) (loop (car node*) (cdr node*))))
             (let loop ((si 0) (rlb* '()))
               (define (wrap-rlb* body) (if (null? rlb*) body (HLL:let* #f (reverse rlb*) body)))
               (if (< si slen)
                   (let ((n* (mvector-ref scc* si)) (si (+ si 1)))
                     (if (null? (cdr n*))
                         (let* ((n (car n*)) (lb (let-binding (node-lhs n) (node-rhs n))))
                           (if (memv n (node-edge* n))
                               (wrap-rlb* (HLL:letrec #f (list lb) (loop si '())))
                               (loop si (cons lb rlb*))))
                         (let ((lb* (let loop ((n* n*) (lb* '()) (cllb* '()))
                                      (if (null? n*)
                                          (append cllb* lb*)
                                          (let ((n (car n*)) (n* (cdr n*)))
                                            (let ((lb (let-binding (node-lhs n) (node-rhs n))))
                                              (if (node-cl? n)
                                                  (loop n* lb* (cons lb cllb*))
                                                  (loop n* (cons lb lb*) cllb*))))))))
                           (wrap-rlb* (HLL:letrec #f lb* (loop si '()))))))
                   (wrap-rlb* (Expr body)))))))
       (let ((node* (let loop ((lb* lb*) (node*.tail '()))
                      (if (null? lb*)
                          node*.tail
                          (let ((lb (car lb*)) (node* (loop (cdr lb*) node*.tail)))
                            (let handle-lb ((lhs (let-binding-lhs lb)) (rhs (let-binding-rhs lb)))
                              (let retry ((rhs rhs))
                                (define (finish cl?)
                                  (let ((node (make-node lhs rhs cl? &active-src)))
                                    (when lhs (set-hllvar-data! lhs node))
                                    (cons node node*)))
                                (HLL-case
                                  rhs
                                  ((letrec lb* body) (loop lb* (handle-lb lhs body)))
                                  ((let*   lb* body) (loop lb* (handle-lb lhs body)))
                                  ((late   &e)       (retry (unbox &e)))
                                  ((case-lambda _)   (finish #t))
                                  (_                 (finish #f))))))))))
         (let loop ((node* node*) (rlb* '()))
           (define (wrap-rlb* body) (if (null? rlb*) body (HLL:let* #f (reverse rlb*) body)))
           (if (null? node*)
               (wrap-rlb* (Expr body))
               (let ((node (car node*)) (node* (cdr node*)))
                 (node-Expr-rhs! node)
                 (let ((edge* (node-edge* node)))
                   (cond ((null? edge*)  ; no recursion
                          (let ((lhs (node-lhs node)))
                            (when lhs (set-hllvar-data! lhs #f))
                            (loop node* (cons (let-binding lhs (node-rhs node)) rlb*))))
                         ((and (eqv? (car edge*) node) (null? (cdr edge*)))  ; self-reference only
                          (let ((lhs (node-lhs node)))
                            (set-hllvar-data! lhs #f)
                            (wrap-rlb* (HLL:letrec #f (list (let-binding lhs (node-rhs node)))
                                                   (loop node* '())))))
                         (else (for-each node-Expr-rhs! node*)  ; at least one downward edge
                               (wrap-rlb* (stratify node node*))))))))))
      ((let* lb* body)           (let ((lb* (lb*-map (lambda (l r) (let-binding l (Expr r))) lb*)))
                                   (HLL:let* note lb* (Expr body))))
      ((apply/values rator rand) (HLL:apply/values note (Expr rator) (Expr rand)))
      ((case-values rand clc*)   (HLL:case-values note (Expr rand) (CLC* clc*)))
      ((late &e)                 (Expr (unbox &e)))))
  (Expr P))

;; HLL-sink-join-points is a direct-style approach to contification.
;; See the following for detail about contification in CPS and SSA:
;; https://www.cs.rit.edu/~mtf/research/contification/ICFP01/icfp01.pdf
;; https://www.microsoft.com/en-us/research/wp-content/uploads/2007/10/compilingwithcontinuationscontinued.pdf
;; For efficiency, it is recommended to HLL-stratify-letrec before HLL-sink-join-points.
;; - For pathological inputs, this solution is quadratic in the size of a letrec binding graph
;;   because it implicitly builds a dominator tree by iterating knode-parent updates and meets.
;; - But this could be improved by reframing the solution in terms of an explicit dominator tree
;;   that is built more efficiently.
(define (HLL-sink-join-points P)
  (mdefine join-point* '())
  (define k.escape #f)
  (define k.pending 'pending)
  (define k-escape? not)
  (define (k-pending? k) (eqv? k k.pending))
  (define (make-knode rec? parent)
    (let ((kn (mvector #f (if (k-escape? parent) 0 (+ (knode-level parent) 1))
                       parent #f '() (if rec? '() #f))))
      (mvector-set! kn 0 (if (k-escape? parent) kn (knode-root0 parent)))
      kn))
  (define (make-knode-rec    parent) (make-knode #t parent))
  (define (make-knode-nonrec parent) (make-knode #f parent))
  (define (knode-root0   kn) (mvector-ref kn 0))
  (define (knode-level   kn) (mvector-ref kn 1))
  (define (knode-parent  kn) (mvector-ref kn 2))
  (define (knode-body    kn) (mvector-ref kn 3))
  (define (knode-sink*   kn) (mvector-ref kn 4))
  (define (knode-passed* kn) (mvector-ref kn 5))
  (define (set-knode-parent!  kn x)  (mvector-set! kn 2 x))
  (define (set-knode-body!    kn b)  (mvector-set! kn 3 b))
  (define (set-knode-sink*!   kn x*) (mvector-set! kn 4 x*))
  (define (set-knode-passed*! kn x*) (mvector-set! kn 5 x*))
  (define (knode-sink! kn lb) (set-knode-sink*! kn (cons lb (knode-sink* kn))))
  (define (knode-pass! kn x) (let ((passed* (knode-passed* kn)))
                               (when passed* (set-knode-passed*! kn (cons x passed*)))))
  (define (knode-call-passed! kn)
    (for-each (let ((k (knode-parent kn))) (lambda (c) (candidate-call! c k))) (knode-passed* kn)))
  (define (knode-bind! kn lb* rec?)
    (let ((b (knode-body kn))) (set-box! b ((if rec? HLL:letrec HLL:let*) #f lb* (unbox b)))))
  (define (make-candidate k.home rhs queue) (mvector k.home k.pending queue rhs #f))
  (define (candidate-home-k    c) (mvector-ref c 0))
  (define (candidate-current-k c) (mvector-ref c 1))
  (define (candidate-queue     c) (mvector-ref c 2))
  (define (candidate-rhs       c) (mvector-ref c 3))
  (define (candidate-body-k*   c) (mvector-ref c 4))
  (define (set-candidate-current-k! c x) (mvector-set! c 1 x))
  (define (set-candidate-queue!     c x) (mvector-set! c 2 x))
  (define (set-candidate-rhs!       c x) (mvector-set! c 3 x))
  (define (set-candidate-body-k*!   c x) (mvector-set! c 4 x))
  (define (candidate-call! c k)
    (define (update! knext)
      (set-candidate-current-k! c knext)
      (unless (or (k-escape? knext) (knode-body knext)) (set-knode-body! knext (box #f)))
      (let ((body-k* (candidate-body-k* c)))
        (when body-k* (for-each (lambda (k) (set-knode-parent! k knext)) body-k*)))
      (let ((q (candidate-queue c))) (when q (queue-push! q c))))
    (let ((k.c (candidate-current-k c)))
      (unless (or (k-escape? k.c) (eqv? k k.c))
        (cond
          ((or (k-pending? k.c) (k-escape? k))            (update! k))
          ((not (eqv? (knode-root0 k) (knode-root0 k.c))) (update! k.escape))
          (else (let meet ((a k) (la (knode-level k)) (b k.c) (lb (knode-level k.c)))
                  (cond ((< la lb)
                         (let ((b0 b) (b (knode-parent b)))
                           (cond ((k-escape? b) (update! k.escape))
                                 (else (knode-pass! b0 c)
                                       (if (eqv? a b)
                                           (unless (eqv? k.c a) (update! a))
                                           (meet a la b (knode-level b)))))))
                        ((< lb la)
                         (let ((a0 a) (a (knode-parent a)))
                           (cond ((k-escape? a) (update! k.escape))
                                 (else (knode-pass! a0 c)
                                       (if (eqv? a b)
                                           (unless (eqv? k.c a) (update! a))
                                           (meet a (knode-level a) b lb))))))
                        (else
                          (let ((a0 a) (b0 b) (a (knode-parent a)) (b (knode-parent b)))
                            (cond ((k-escape? a) (update! k.escape))
                                  ((k-escape? b) (update! k.escape))
                                  (else (knode-pass! a0 c) (knode-pass! b0 c)
                                        (if (eqv? a b)
                                            (unless (eqv? k.c a) (update! a))
                                            (meet a (knode-level a) b (knode-level b))))))))))))))
  (define (make-queue) (box '()))
  (define (queue-empty? q) (null? (unbox q)))
  (define (queue-push! q c) (set-candidate-queue! c #f) (set-box! q (cons c (unbox q))))
  (define (queue-run! q) (let ((c* (unbox q)))
                           (set-box! q '())
                           (for-each (lambda (c)
                                       (set-candidate-queue! c q)
                                       (let ((body-k* (candidate-body-k* c)))
                                         (if body-k*
                                             (for-each knode-call-passed! body-k*)
                                             (set-candidate-rhs! c (JP-rec c)))))
                                     c*)))
  (define (lb*-register lb* k.home queue)
    (let loop ((lb* lb*))
      (if (null? lb*)
          '()
          (let ((lb (car lb*)) (lb* (loop (cdr lb*))))
            (let ((lhs (let-binding-lhs lb)))
              (let ((rhs (and lhs (let retry ((rhs (let-binding-rhs lb)))
                                    (HLL-case rhs
                                              ((case-lambda _) rhs)
                                              ((late &e)       (retry (unbox &e)))
                                              (_               #f))))))
                (if rhs
                    (begin (set-hllvar-data! lhs (make-candidate k.home rhs queue)) (cons lhs lb*))
                    lb*)))))))
  (define (CLC*/Expr Expr clc*) (clc*-map (lambda (a p b) (cl-clause a p (Expr b))) clc*))
  (define (Late/k k x) (let ((e (Expr/k k x)) (b (knode-body k)))
                         (if b (begin (set-box! b e) (HLL:late #f b)) e)))
  (define (Nontail x) (Late/k (make-knode-nonrec k.escape) x))
  (define (Ref k v x) (let ((c (hllvar-data v))) (when c (candidate-call! c k))) x)
  (define (JP-rec c)
    (let ((k (candidate-current-k c)) (x (candidate-rhs c)))
      (HLL-case
        x
        ((case-lambda clc*)
         (mdefine body-k* '())
         (let ((x (HLL:case-lambda (HLL-note x) (CLC*/Expr (lambda (x)
                                                             (let ((k (make-knode-rec k)))
                                                               (set! body-k* (cons k body-k*))
                                                               (Late/k k x)))
                                                           clc*))))
           (set-candidate-body-k*! c body-k*)
           x)))))
  (define (JP-nonrec k c)
    (let ((x (candidate-rhs c)))
      (HLL-case x ((case-lambda clc*)
                   (HLL:case-lambda (HLL-note x) (CLC*/Expr (lambda (x) (Expr/k k x)) clc*))))))
  (define (Expr/k k x)
    (define (Tail x) (Expr/k k x))
    (define (Rator x)
      (HLL-case x ((ref v) (Ref k v x)) ((late &e) (Rator (unbox &e))) (_ (Nontail x))))
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref v)             (Ref k.escape v x))
      ((prim-ref _)        x)
      ((quote _)           x)
      ((if c t f)          (HLL:if note (Nontail c) (Tail t) (Tail f)))
      ((begin e^ e)        (HLL:begin note (tree-map Nontail e^) (Tail e)))
      ((call rator rand*)  (HLL:call note (Rator rator) (map Nontail rand*)))
      ((prim-call p rand*) (HLL:prim-call note p (map Nontail rand*)))
      ((case-lambda clc*)  (HLL:case-lambda note (CLC*/Expr Nontail clc*)))
      ((letrec lb* body)
       (mdefine k*.sink '())
       (let* ((q (make-queue))
              (registered* (lb*-register lb* k q))
              (body (Tail body))
              (lb* (let loop ((lb* lb*))
                     (if (null? lb*)
                         '()
                         (let ((lb (car lb*)) (lb* (loop (cdr lb*))))
                           (let ((lhs (let-binding-lhs lb)))
                             (if (and lhs (hllvar-data lhs))
                                 lb*
                                 (cons (let-binding lhs (Nontail (let-binding-rhs lb))) lb*)))))))
              (lb* (begin
                     (let loop () (unless (queue-empty? q) (queue-run! q) (loop)))
                     (let loop ((lhs* registered*))
                       (if (null? lhs*)
                           lb*
                           (let ((lhs (car lhs*)) (lb* (loop (cdr lhs*))))
                             (let* ((c (hllvar-data lhs)) (k.c (candidate-current-k c)))
                               (cond ((k-pending? k.c) lb*)
                                     ((k-escape? k.c)
                                      (cons (let-binding lhs (candidate-rhs c)) lb*))
                                     ((eqv? (candidate-home-k c) k.c)
                                      (set! join-point* (cons lhs join-point*))
                                      (cons (let-binding lhs (candidate-rhs c)) lb*))
                                     (else (knode-sink! k.c (let-binding lhs (candidate-rhs c)))
                                           (set! k*.sink (cons k.c k*.sink))
                                           (set! join-point* (cons lhs join-point*))
                                           lb*)))))))))
         (for-each (lambda (kn) (let ((lb* (knode-sink* kn))) (unless (null? lb*)
                                                                (set-knode-sink*! kn '())
                                                                (knode-bind! kn lb* #t))))
                   k*.sink)
         (for-each (lambda (x) (set-hllvar-data! x #f)) registered*)
         (if (null? lb*) body (HLL:letrec note lb* body))))
      ((let* lb* body)
       (mdefine k*.sink '())
       (let ((registered* (lb*-register lb* k #f))
             (body (Tail body))
             (lb* (let loop ((lb* lb*))
                    (if (null? lb*)
                        '()
                        (let* ((lb (car lb*))
                               (lb* (loop (cdr lb*)))
                               (lhs (let-binding-lhs lb)) (rhs (let-binding-rhs lb))
                               (c (and lhs (hllvar-data lhs)))
                               (k.c (if c (candidate-current-k c) k.escape)))
                          (cond ((k-pending? k.c) lb*)
                                ((k-escape? k.c) (cons (let-binding lhs (Nontail rhs)) lb*))
                                ((eqv? (candidate-home-k c) k.c)
                                 (set! join-point* (cons lhs join-point*))
                                 (cons (let-binding lhs (JP-nonrec k.c c)) lb*))
                                (else (knode-sink! k.c (let-binding lhs (JP-nonrec k.c c)))
                                      (set! k*.sink (cons k.c k*.sink))
                                      (set! join-point* (cons lhs join-point*))
                                      lb*)))))))
         (for-each (lambda (kn) (let ((lb* (knode-sink* kn))) (unless (null? lb*)
                                                                (set-knode-sink*! kn '())
                                                                (knode-bind! kn lb* #f))))
                   k*.sink)
         (for-each (lambda (x) (set-hllvar-data! x #f)) registered*)
         (if (null? lb*) body (HLL:let* note lb* body))))
      ((apply/values rator rand) (HLL:apply/values note (Nontail rator) (Nontail rand)))
      ((case-values rand clc*)   (HLL:case-values note (Nontail rand) (CLC*/Expr Tail clc*)))
      ((late &e)                 (Tail (unbox &e)))))
  (let ((P (Nontail P))) (values join-point* P)))

(define (HLL-convert-letrec P)
  (let Expr ((x P))
    (define (CLC* clc*) (clc*-map (lambda (a p body) (cl-clause a p (Expr body))) clc*))
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref v)             (if (hllvar-data v) (HLL: (/note note (unbox v))) x))
      ((prim-ref _)        x)
      ((quote v)           x)
      ((if c t f)          (HLL:if note (Expr c) (Expr t) (Expr f)))
      ((begin e^ e)        (HLL:begin note (tree-map Expr e^) (Expr e)))
      ((call rator rand*)  (HLL:call note (Expr rator) (map Expr rand*)))
      ((prim-call p rand*) (HLL:prim-call note p (map Expr rand*)))
      ((case-lambda clc*)  (HLL:case-lambda note (CLC* clc*)))
      ((letrec lb* body)
       (mdefine lb*.lam '())
       (mdefine lb*.other '())
       (lb*-for-each (lambda (lhs rhs)
                       (let retry ((rhs rhs))
                         (HLL-case
                           rhs
                           ((case-lambda clc*)
                            (when lhs (set! lb*.lam (cons (let-binding lhs rhs) lb*.lam))))
                           ((late &e) (retry (unbox &e)))
                           (_ (when lhs (set-hllvar-data! lhs #t))
                              (set! lb*.other (cons (let-binding lhs rhs) lb*.other))))))
                     lb*)
       (mdefine lb*.box '())
       (mdefine effect^ #f)
       (define (effect! e) (let ((e^ effect^)) (if e^ (set! effect^ (cons e e^)) (set! effect^ e))))
       (lb*-for-each (lambda (lhs rhs)
                       (let ((rhs (Expr rhs)))
                         (if lhs
                             (begin (set! lb*.box (cons (let-binding lhs (HLL: (box #t))) lb*.box))
                                    (effect! (HLL: (set-box! lhs ,rhs))))
                             (effect! rhs))))
                     lb*.other)
       (let* ((body (let ((e^ effect^) (body (Expr body))) (if e^ (HLL: (begin ,e^ ,body)) body)))
              (lb*.lam (lb*-map (lambda (lhs rhs) (let-binding lhs (Expr rhs))) (reverse lb*.lam)))
              (body (if (null? lb*.lam) body (HLL:letrec note lb*.lam body)))
              (lb*.box lb*.box)
              (body (if (null? lb*.box) body (HLL:let* #f lb*.box body))))
         (lb*-for-each (lambda (lhs _) (set-hllvar-data! lhs #f)) lb*.box)
         body))
      ((let* lb* body)           (define (LB lhs rhs) (let-binding lhs (Expr rhs)))
                                 (HLL:let* note (lb*-map LB lb*) (Expr body)))
      ((apply/values rator rand) (HLL:apply/values note (Expr rator) (Expr rand)))
      ((case-values rand clc*)   (HLL:case-values note (Expr rand) (CLC* clc*)))
      ((late &e)                 (Expr (unbox &e))))))

(define (HLL-bind-lambda P)
  (define (CLC* clc*) (clc*-map (lambda (a p body) (cl-clause a p (Expr body))) clc*))
  (define (Expr x) (Expr/k x values (lambda (rhs) (let ((lhs (hllvar #f #f)))
                                                    (HLL: (letrec ((lhs ,rhs)) lhs))))))
  (define (Expr/k x k k.lambda)
    (define (Expr/current x) (Expr/k x k k.lambda))
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref _)             (k x))
      ((prim-ref _)        (k x))
      ((quote _)           (k x))
      ((if c t f)          (k (HLL:if note (Expr c) (Expr t) (Expr f))))
      ((begin e^ e)        (k (HLL:begin note (tree-map Expr e^) (Expr e))))
      ((call rator rand*)  (k (HLL:call note (Expr rator) (map Expr rand*))))
      ((prim-call p rand*) (k (HLL:prim-call note p (map Expr rand*))))
      ((case-lambda clc*)  (k.lambda (HLL:case-lambda note (CLC* clc*))))
      ((letrec lb* body)   (define (LB lhs rhs) (let-binding lhs (Expr/k rhs values values)))
                           (k (HLL:letrec note (lb*-map LB lb*) (Expr body))))
      ((let* lb* body)
       (if (null? lb*)
           (Expr/current body)
           (k (let outer-loop ((note note) (lb* lb*))
                (if (null? lb*)
                    (Expr body)
                    (let ((lb (car lb*)) (lb* (cdr lb*)))
                      (let ((lhs (let-binding-lhs lb)) (rhs (let-binding-rhs lb)))
                        (define (k rhs)
                          (let split-loop ((lb* lb*) (prev* (list (let-binding lhs rhs))))
                            (if (null? lb*)
                                (HLL: (/note note (let* ,(reverse prev*) ,(Expr body))))
                                (let ((lb (car lb*)) (lb* (cdr lb*)))
                                  (let ((lhs (let-binding-lhs lb)) (rhs (let-binding-rhs lb)))
                                    (define (k rhs)
                                      (split-loop lb* (cons (let-binding lhs rhs) prev*)))
                                    (define (k.lambda rhs)
                                      (if lhs
                                          (HLL: (/note note (let* ,(reverse prev*)
                                                              (letrec ((lhs ,rhs))
                                                                ,(outer-loop #f lb*)))))
                                          (split-loop lb* prev*)))
                                    (Expr/k rhs k k.lambda))))))
                        (define (k.lambda rhs)
                          (if lhs
                              (HLL: (/note note (letrec ((lhs ,rhs)) ,(outer-loop #f lb*))))
                              (outer-loop note lb*)))
                        (Expr/k rhs k k.lambda))))))))
      ((apply/values rator rand) (k (HLL:apply/values note (Expr rator) (Expr rand))))
      ((case-values rand clc*)   (k (HLL:case-values note (Expr rand) (CLC* clc*))))
      ((late &e)                 (Expr/current (unbox &e)))))
  (Expr P))

(define (HLL-map-quote P f)
  (define (Let-binding* lb*) (lb*-map (lambda (lhs rhs) (let-binding lhs (Expr rhs))) lb*))
  (define (CLC* clc*) (clc*-map (lambda (a p body) (cl-clause a p (Expr body))) clc*))
  (define (Expr x)
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref _)                   x)
      ((prim-ref _)              x)
      ((quote v)                 (f x note v))
      ((if c t f)                (HLL:if note (Expr c) (Expr t) (Expr f)))
      ((begin e^ e)              (HLL:begin note (tree-map Expr e^) (Expr e)))
      ((call rator rand*)        (HLL:call note (Expr rator) (map Expr rand*)))
      ((prim-call p rand*)       (HLL:prim-call note p (map Expr rand*)))
      ((case-lambda clc*)        (HLL:case-lambda note (CLC* clc*)))
      ((letrec lb* body)         (HLL:letrec note (Let-binding* lb*) (Expr body)))
      ((let* lb* body)           (HLL:let*   note (Let-binding* lb*) (Expr body)))
      ((apply/values rator rand) (HLL:apply/values note (Expr rator) (Expr rand)))
      ((case-values rand clc*)   (HLL:case-values note (Expr rand) (CLC* clc*)))
      ((late &e)                 (Expr (unbox &e)))))
  (Expr P))

(define (HLL-normalize-quote P)
  (mdefine lb* '())
  (define (proc->primop proc note) (let ((p (procedure->primop proc)))
                                     (if p (HLL:prim-ref note p) (HLL:quote note proc))))
  (define p.cons   (proc->primop cons #f))
  (define p.vector (proc->primop vector #f))
  (let ((x (HLL-map-quote
             P (lambda (x note v)
                 (let loop/note ((v v) (note note))
                   (define (loop v) (loop/note v #f))
                   (cond ((immediate? v) (HLL:quote note v))
                         ((procedure? v) (proc->primop v note))
                         (else (let ((t (hllvar #f #f))
                                     (x (cond ((pair? v) (HLL:call p.cons #f (list (loop (car v))
                                                                                   (loop (cdr v)))))
                                              ((vector? v) (HLL:call p.vector #f
                                                                     (map loop (vector->list v))))
                                              (else (HLL:quote #f v)))))
                                 (set! lb* (cons (let-binding t x) lb*))
                                 (HLL:ref note t)))))))))
    (if (null? lb*) x (HLL:let* #f lb* x))))

(define (HLL-procedure=>free-variable* P)
  (define (make-clo) (box '()))
  (define (clo-free! clo v) (set-box! clo (cons v (unbox clo))))
  (define (make-seen clo* depth) (mvector depth clo* depth))
  (define (seen-top-depth s) (mvector-ref s 0))
  (define (seen-clo*      s) (mvector-ref s 1))
  (define (seen-depth     s) (mvector-ref s 2))
  (define (seen-set! s clo* depth) (mvector-set! s 1 clo*) (mvector-set! s 2 depth))
  (mdefine lhs=>clo '())
  (define (CLC* clo* depth clc*)
    (clc*-for-each (lambda (a p*~ body)
                     (param-for-each (lambda (p) (set-hllvar-data! p (make-seen clo* depth))) p*~)
                     (Expr/clo clo* depth body)
                     (param-for-each (lambda (p) (set-hllvar-data! p #f)) p*~))
                   clc*))
  (define (CL lhs clo* depth x)
    (HLL-case
      x
      ((case-lambda clc*) (let* ((clo (make-clo)) (clo* (cons clo clo*)) (depth (+ depth 1)))
                            (set! lhs=>clo (cons (cons lhs clo) lhs=>clo))
                            (CLC* clo* depth clc*)))
      ((late &e)          (CL lhs clo* depth (unbox &e)))))
  (define (Expr/clo clo* depth x)
    (define (Expr x) (Expr/clo clo* depth x))
    (define (Let* lb* body)
      (lb*-for-each (lambda (lhs rhs)
                      (when lhs (set-hllvar-data! lhs (make-seen clo* depth)))
                      (Expr/clo clo* depth rhs))
                    lb*)
      (Expr body)
      (lb*-for-each (lambda (lhs _) (when lhs (set-hllvar-data! lhs #f))) lb*))
    (define (Letrec lb* body)
      (lb*-for-each (lambda (lhs _) (when lhs (set-hllvar-data! lhs (make-seen clo* depth)))) lb*)
      (lb*-for-each (lambda (lhs rhs) (CL lhs clo* depth rhs)) lb*)
      (Expr body)
      (lb*-for-each (lambda (lhs _) (when lhs (set-hllvar-data! lhs #f))) lb*))
    (HLL-case
      x
      ((ref v)
       (let* ((s (hllvar-data v)) (td (seen-top-depth s)) (d (seen-depth s)) (c* (seen-clo* s)))
         (unless (= td 0)  ; NOTE: top-level variables are not stored in closures
           (seen-set! s clo* depth)
           (define (k d c* clo*) (when (< td d) (let ((clo (car clo*)))
                                                  (unless (eqv? clo (car c*))
                                                    (clo-free! clo v)
                                                    (k (- d 1) (cdr c*) (cdr clo*))))))
           (if (< d depth)
               (let loop ((depth depth) (clo* clo*))
                 (clo-free! (car clo*) v)
                 (let ((depth (- depth 1)) (clo* (cdr clo*)))
                   (if (< d depth) (loop depth clo*) (k d c* clo*))))
               (k depth (drop (- d depth) c*) clo*)))))
      ((prim-ref _)              (values))
      ((quote _)                 (values))
      ((if c t f)                (Expr c) (Expr t) (Expr f))
      ((begin e^ e)              (tree-for-each Expr e^) (Expr e))
      ((call rator rand*)        (Expr rator) (for-each Expr rand*))
      ((prim-call p rand*)       (for-each Expr rand*))
      ((letrec lb* body)         (Letrec lb* body))
      ((let* lb* body)           (Let* lb* body))
      ((apply/values rator rand) (Expr rator) (Expr rand))
      ((case-values rand clc*)   (Expr rand) (CLC* clo* depth clc*))
      ((late &e)                 (Expr (unbox &e)))))
  (Expr/clo '() 0 P)
  (alist-map-value unbox lhs=>clo))

(define (HLL-well-known-procedure* P var*.procedure)
  (for-each (lambda (v) (set-hllvar-data! v #t)) var*.procedure)
  (define (Let lb* body) (lb*-for-each (lambda (_ rhs) (Expr rhs)) lb*) (Expr body))
  (define (CLC* clc*) (clc*-for-each (lambda (a p body) (Expr body)) clc*))
  (define (Expr x) (Expr/rator? #f x))
  (define (Expr/rator? rator? x)
    (HLL-case
      x
      ((ref v)                   (unless rator? (set-hllvar-data! v #f)))
      ((prim-ref _)              (values))
      ((quote _)                 (values))
      ((if c t f)                (Expr c) (Expr t) (Expr f))
      ((begin e^ e)              (tree-for-each Expr e^) (Expr e))
      ((call rator rand*)        (Expr/rator? #t rator) (for-each Expr rand*))
      ((prim-call p rand*)       (for-each Expr rand*))
      ((case-lambda clc*)        (CLC* clc*))
      ((letrec lb* body)         (Let lb* body))
      ((let* lb* body)           (Let lb* body))
      ((apply/values rator rand) (Expr rator) (Expr rand))
      ((case-values rand clc*)   (Expr rand) (CLC* clc*))
      ((late &e)                 (Expr/rator? rator? (unbox &e)))))
  (Expr P)
  (filter (lambda (v) (let ((wk? (hllvar-data v))) (set-hllvar-data! v #f) wk?)) var*.procedure))

;; Recognize joint points as described in:
;; https://www.microsoft.com/en-us/research/wp-content/uploads/2016/11/compiling-without-continuations.pdf
;; NOTE: rather than transform join points, we will transform exit points directly, inspired by:
;; https://www.cs.purdue.edu/homes/rompf/papers/cong-icfp19.pdf
(define (HLL-join-point* P var*.well-known)
  (define (make-candidate) (make-mvector 2 #f))
  (define (candidate-level c) (mvector-ref c 0))
  (define (candidate-rhs   c) (mvector-ref c 1))
  (define (candidate-set! c level rhs)
    (mvector-set! c 0 level)
    (mvector-set! c 1 rhs))
  (for-each (lambda (v) (set-hllvar-data! v (make-candidate))) var*.well-known)
  (mdefine non-tail* '())
  (define (Expr/level level x)
    (define level+1 (and level (+ level 1)))
    (define (Expr x) (Expr/level level+1 x))
    (define (Tail x) (Expr/level level x))
    (define (CLC* clc*) (clc*-for-each (lambda (a p body) (Tail body)) clc*))
    (HLL-case
      x
      ((ref v)                   (let ((c (hllvar-data v)))
                                   (when (and c (not (eqv? (candidate-level c) level)))
                                     (set-hllvar-data! v #f)
                                     (set! non-tail* (cons c non-tail*)))))
      ((prim-ref _)              (values))
      ((quote _)                 (values))
      ((if c t f)                (Expr c) (Tail t) (Tail f))
      ((begin e^ e)              (tree-for-each Expr e^) (Tail e))
      ((call rator rand*)        (Tail rator) (for-each Expr rand*))
      ((prim-call p rand*)       (for-each Expr rand*))
      ((case-lambda clc*)        (CLC* clc*))
      ((letrec lb* body)         (lb*-for-each (lambda (lhs rhs)
                                                 (let ((c (and lhs (hllvar-data lhs))))
                                                   (when c (candidate-set! c level rhs))))
                                               lb*)
                                 (Tail body)
                                 (lb*-for-each (lambda (lhs rhs) (if (and lhs (hllvar-data lhs))
                                                                     (Tail rhs)
                                                                     (Expr rhs)))
                                               lb*))
      ((let* lb* body)           (lb*-for-each (lambda (_ rhs) (Expr rhs)) lb*) (Tail body))
      ((apply/values rator rand) (Expr rator) (Expr rand))
      ((case-values rand clc*)   (Expr rand) (CLC* clc*))
      ((late &e)                 (Tail (unbox &e)))))
  (Expr/level 0 P)
  (let loop () (let ((c* non-tail*))
                 (unless (null? c*)
                   (set! non-tail* '())
                   (for-each (lambda (c) (Expr/level (+ (candidate-level c) 1) (candidate-rhs c)))
                             c*)
                   (loop))))
  (filter (lambda (v) (let ((jp? (hllvar-data v))) (set-hllvar-data! v #f) jp?)) var*.well-known))

(define (HLL-create-closures P proc=>fv*)
  (define (make-cdata vlam fv*) (cons vlam fv*))
  (define cdata-vlam car)
  (define cdata-fv*  cdr)
  (alist-for-each (lambda (proc fv*) (let ((vlam (hllvar (hllvar-name proc) (hllvar-source proc))))
                                       (set-hllvar-data! vlam fv*)
                                       (set-hllvar-data! proc (make-cdata vlam fv*))))
                  proc=>fv*)
  (define (make-cref prev clo i) (vector prev clo i))
  (define (cref-prev  cr) (vector-ref cr 0))
  (define (cref-clo   cr) (vector-ref cr 1))
  (define (cref-index cr) (vector-ref cr 2))
  (define (var-cref v note) (let ((cr (hllvar-data v)))
                              (and cr (HLL:closure-ref note (cref-clo cr) (cref-index cr)))))
  (define (CL fv* x)
    (HLL-case
      x
      ((case-lambda clc*)
       (define (make-cl a p b)
         (let* ((pclo (hllvar 'clo #f)) (clo (HLL:ref #f pclo)))
           (let loop ((i 1) (fv* fv*))
             (unless (null? fv*)
               (let ((fv (car fv*)))
                 (set-hllvar-data! fv (make-cref (hllvar-data fv) clo (HLL:quote #f i)))
                 (loop (+ i 1) (cdr fv*)))))
           (let ((b (Expr b)))
             (for-each (lambda (fv) (set-hllvar-data! fv (cref-prev (hllvar-data fv)))) fv*)
             (cl-clause (arity+ a 1) (cons pclo p) b))))
       (HLL:case-lambda (HLL-note x) (clc*-map make-cl clc*)))
      ((late &e) (CL fv* (unbox &e)))))
  (define (Expr x)
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref v)             (or (var-cref v note) x))
      ((prim-ref _)        x)
      ((quote _)           x)
      ((if c t f)          (HLL:if note (Expr c) (Expr t) (Expr f)))
      ((begin e^ e)        (HLL:begin note (tree-map Expr e^) (Expr e)))
      ((prim-call p rand*) (HLL:prim-call note p (map Expr rand*)))
      ((call rator rand*)  (HLL:closure-call note (Expr rator) (map Expr rand*)))
      ((letrec lb* body)
       (define (fv->ref fv) (or (var-cref fv #f) (HLL:ref #f fv)))
       (define (lc->cset!^ lc)
         (let ((clo (HLL:ref #f (car lc))) (cd (cdr lc)))
           (define (make-cset! i ref) (HLL:closure-set! #f clo (HLL:quote #f i) ref))
           (fold-left (mlet ((i 1)) (lambda (e fv) (let ((cs (make-cset! i (fv->ref fv))))
                                                     (set! i (+ i 1)) (cons e cs))))
                      (make-cset! 0 (HLL:ref #f (cdata-vlam cd)))
                      (cdata-fv* cd))))
       (define (lc*->cset!^ lc*)
         (fold-left (lambda (e lc) (cons e (lc->cset!^ lc))) (lc->cset!^ (car lc*)) (cdr lc*)))
       (define (cd->mclo cd) (HLL:make-closure #f (HLL:quote #f (+ (length (cdata-fv* cd)) 1))))
       (if (null? lb*)
           (Expr body)
           (let* ((lc* (lb*-map (lambda (l _) (let ((cd (hllvar-data l))) (cons l cd))) lb*))
                  (lb* (lb*-map (lambda (l r) (let ((vlam (cdata-vlam (hllvar-data l))))
                                                (set-hllvar-data! l #f)
                                                (let-binding vlam r)))
                                lb*))
                  (lb* (lb*-map (lambda (l r) (let ((fv* (hllvar-data l)))
                                                (set-hllvar-data! l #f)
                                                (let-binding l (CL fv* r))))
                                lb*))
                  (cb* (alist-map (lambda (l cd) (let-binding l (cd->mclo cd))) lc*)))
             (HLL:let* #f cb* (HLL:letrec note lb* (HLL:begin #f (lc*->cset!^ lc*) (Expr body)))))))
      ((let* lb* body)
       (HLL:let* note (lb*-map (lambda (l r) (let-binding l (Expr r))) lb*) (Expr body)))
      ((apply/values rator rand) (HLL:apply/values note (Expr rator) (Expr rand)))
      ((case-values rand clc*)
       (HLL:case-values note (Expr rand) (clc*-map (lambda (a p b) (cl-clause a p (Expr b))) clc*)))
      ((late &e) (Expr (unbox &e)))))
  (Expr P))

;; Create flat closures, omitting free-variable fields for self-references and unnecessary
;; mutually-recursive references, omitting closures for empty well-known procedures and join points,
;; simplifying closure representations for well-known procedures, and sharing closures when it does
;; not jeopardize space-safety.  When determining closures that are safe to share, the call graph of
;; procedures bound by each letrec is assumed to consist of a single, strongly-connected component,
;; implying that they all share the same lifetime.  We can satisfy this assumption by running
;; HLL-stratify-letrec first.
;; For more detail about closure optimization, see Andy Keep's dissertation, Chapter 5:
;; https://andykeep.com/pubs/dissertation.pdf
;; and Optimizing Closures in O(0) time:
;; https://andykeep.com/pubs/scheme-12a.pdf
(define (HLL-create-optimized-closures P proc=>fv* well-known* join-point*)
  (define tag.seen       'seen)
  (define tag.known      'known)
  (define tag.well-known 'wknown)
  (define tag.join-point 'jp)
  (define (known!      v) (set-hllvar-data2! v tag.known))
  (define (well-known! v) (set-hllvar-data2! v tag.well-known))
  (define (known?      v) (eqv? (hllvar-data2 v) tag.known))
  (define (well-known? v) (eqv? (hllvar-data2 v) tag.well-known))
  (mdefine v=>data2 '())
  (alist-for-each (lambda (v fv*)
                    (set! v=>data2 (cons (cons v (hllvar-data2 v)) v=>data2))
                    (set-hllvar-data! v fv*)
                    (known! v))
                  proc=>fv*)
  (for-each well-known! well-known*)
  (for-each (lambda (v) (set-hllvar-data! v tag.join-point)) join-point*)
  (define (fv*-normalize fv*)
    (let loop ((fv* fv*) (fv=>x '()))
      (if (null? fv*)
          (alist-map (lambda (fv x) (set-hllvar-data! fv x) fv) (reverse fv=>x))
          (let retry ((fv (car fv*)))
            (let ((x (hllvar-data fv)))
              (cond ((hllvar? x)       (retry x))
                    ((eqv? x tag.seen) (loop (cdr fv*) fv=>x))
                    (else              (set-hllvar-data! fv tag.seen)
                                       (loop (cdr fv*) (cons (cons fv x) fv=>x)))))))))
  (define (fv*-slot fv*)
    (let loop ((fv* fv*) (i 0) (slot* '()) (fv=>e '()))
      (if (null? fv*)
          (values i slot* fv=>e)
          (let retry ((fv (car fv*)))
            (let ((x (hllvar-data fv)))
              (cond ((hllvar? x) (retry x))
                    ((integer? x) (loop (cdr fv*) i slot* fv=>e))
                    (else (set-hllvar-data! fv i)
                          (loop (cdr fv*) (+ i 1) (cons (or x (HLL:ref #f fv)) slot*)
                                (cons (cons fv x) fv=>e)))))))))
  (define (var-ref v) (let ((e (hllvar-data v))) (cond ((hllvar? e) (var-ref e))
                                                       ((not e)     (HLL:ref #f v))
                                                       (else        e))))
  (define bank.empty '())
  (define (be-len  be) (vector-ref be 0))
  (define (be-vlam be) (vector-ref be 1))
  (define (be-fv*  be) (vector-ref be 2))
  (define (bank-deposit b vlam fv* len) (cons (vector len vlam (cdr fv*)) b))
  (define (bank-filter b fv*)
    (let ((fv=>e (map (lambda (fv) (let ((fv&e (cons fv (hllvar-data fv))))
                                     (set-hllvar-data! fv tag.seen)
                                     fv&e))
                      fv*))
          (b (filter (lambda (be) (eqv? (hllvar-data (be-vlam be)) tag.seen)) b)))
      (alist-for-each set-hllvar-data! fv=>e)
      b))
  (define (bank-find b vlam fv* len)
    (if (null? b)
        (values len #f)
        (let ((fv=>e (map (lambda (fv) (let ((fv&e (cons fv (hllvar-data fv))))
                                         (set-hllvar-data! fv tag.seen)
                                         fv&e))
                          (cdr fv*)))
              (be (ormap (lambda (be)
                           (define (covered?)
                             (andmap (lambda (fv) (eqv? (hllvar-data fv) tag.seen)) (be-fv* be)))
                           (and (case (- len (be-len be))
                                  ((0) (covered?))
                                  ((1) (and (covered?) (eqv? (hllvar-data (be-vlam be)) tag.seen)))
                                  (else #f))
                                be))
                         b)))
          (if be
              (let* ((vlam.be (be-vlam be)) (fv=>e (cons (cons vlam.be #f) fv=>e)))
                (set-hllvar-data! vlam vlam.be)
                (set-hllvar-data! vlam.be 0)
                (let loop ((fv* (be-fv* be)) (i 1)) (unless (null? fv*)
                                                      (set-hllvar-data! (car fv*) i)
                                                      (loop (cdr fv*) (+ i 1))))
                (values (be-len be) fv=>e))
              (begin (alist-for-each set-hllvar-data! fv=>e) (values len #f))))))
  (define (CL CLC x) (let retry ((x x)) (HLL-case
                                          x
                                          ((case-lambda clc*)
                                           (HLL:case-lambda (HLL-note x) (clc*-map CLC clc*)))
                                          ((late &e) (retry (unbox &e))))))
  (define (LB* CLC lb*) (lb*-map (lambda (l r) (let-binding l (CL CLC r))) lb*))
  (define (Expr/bank bank x)
    (define ((CL/fv*/clo-ref clo-ref) bank fv* x)
      (let ((fv=>i (map (lambda (fv) (cons fv (hllvar-data fv))) fv*))
            (bank  (bank-filter bank fv*)))
        (CL (lambda (a p b)
              (let* ((v.clo (hllvar 'clo #f)) (e.clo (HLL:ref #f v.clo)))
                (for-each (lambda (fv)
                            (let ((i (hllvar-data fv)))
                              (set-hllvar-data! fv (if (eqv? i 0) e.clo (clo-ref e.clo i)))))
                          fv*)
                (let ((clc (cl-clause (arity+ a 1) (cons v.clo p) (Expr/bank bank b))))
                  (alist-for-each set-hllvar-data! fv=>i)
                  clc)))
            x)))
    (define CL/fv*.clo (CL/fv*/clo-ref (lambda (c i) (HLL:closure-ref #f c (HLL:quote #f i)))))
    (define CL/fv*.vec (CL/fv*/clo-ref (lambda (c i)
                                         (HLL:unsafe-vector-ref #f c (HLL:quote #f (- i 1))))))
    (define CL/fv*.pair (CL/fv*/clo-ref (lambda (c i) (case i
                                                        ((1) (HLL:unsafe-car #f c))
                                                        ((2) (HLL:unsafe-cdr #f c))))))
    (define CL/fv*.single (CL/fv*/clo-ref (lambda (c i) c)))
    (define (make-wk lhs rhs fv*) (vector lhs rhs fv*))
    (define (wk-lhs wk) (vector-ref wk 0))
    (define (wk-rhs wk) (vector-ref wk 1))
    (define (wk-fv* wk) (vector-ref wk 2))
    (define (wk-normalize wk) (make-wk (wk-lhs wk) (wk-rhs wk) (fv*-normalize (wk-fv* wk))))
    (define (Not-well-known-letrec bank note lb* body)
      ;; There is at least one not-well-known procedure bound by this letrec.  All well-known
      ;; procedures bound here can share a with one of the not-well-known procedures.  We choose to
      ;; share the closure of an arbitrary not-well-known that references at least one such
      ;; well-known procedure as a free variable.
      (let partition ((lb* lb*) (wk* '()) (nwk* '()))
        (if (null? lb*)
            (let ((v.share (and (pair? wk*)
                                (ormap (lambda (nwk) (and (ormap well-known? (vector-ref nwk 2))
                                                          (vector-ref nwk 0)))
                                       nwk*))))
              (for-each (lambda (wk) (let ((v (wk-lhs wk)))
                                       (known! v) (set-hllvar-data! v v.share)))
                        wk*)
              (let* ((wk* (map wk-normalize wk*)) (fv*.wk (append* (map wk-fv* wk*))))
                (let loop ((nwk* nwk*) (clo* '()) (init^ #f) (lb* '()))
                  (if (null? nwk*)
                      (HLL:let* #f clo* (HLL:letrec note lb* (HLL:begin #f init^
                                                                        (Expr/bank bank body))))
                      (let* ((nwk (car nwk*))
                             (nwk* (cdr nwk*)) (lhs (vector-ref nwk 0)) (rhs (vector-ref nwk 1))
                             (v.clo (vector-ref nwk 3)) (e.clo (hllvar-data lhs))
                             (fv* (fv*-normalize (cons lhs (vector-ref nwk 2)))))  ; slot 0 lhs
                        (define (make-cset! i e) (HLL:closure-set! #f e.clo (HLL:quote #f i) e))
                        (set-hllvar-data! lhs #f)  ; slot 0 is for the code, not the closure
                        (let-values (((i slot* fv=>e) (fv*-slot (if (eqv? lhs v.share)
                                                                    (append fv* fv*.wk)
                                                                    fv*))))
                          (let* ((clo (let-binding v.clo (HLL:make-closure #f (HLL:quote #f i))))
                                 (init (let loop ((i (- i 2))
                                                  (slot* (cdr slot*))
                                                  (init^ (make-cset! (- i 1) (car slot*))))
                                         (if (null? slot*)
                                             init^
                                             (loop (- i 1) (cdr slot*)
                                                   (cons (make-cset! i (car slot*)) init^)))))
                                 (lb*.wk (if (eqv? lhs v.share)
                                             (map (lambda (wk)
                                                    (let-binding (wk-lhs wk)
                                                                 (CL/fv*.clo bank (wk-fv* wk)
                                                                             (wk-rhs wk))))
                                                  wk*)
                                             '()))
                                 (lb* (cons (let-binding lhs (CL/fv*.clo bank fv* rhs))
                                            (append lb*.wk lb*))))
                            (alist-for-each set-hllvar-data! fv=>e)
                            (set-hllvar-data! lhs e.clo)  ; reference the closure from now on
                            (loop nwk* (cons clo clo*) (if init^ (cons init init^) init) lb*))))))))
            (let ((lb (car lb*)) (lb* (cdr lb*)))
              (let* ((lhs (let-binding-lhs lb)) (rhs (let-binding-rhs lb)) (fv* (hllvar-data lhs)))
                (if (well-known? lhs)
                    (partition lb* (cons (make-wk lhs rhs fv*) wk*) nwk*)
                    (let* ((v.clo (hllvar 'clo #f)) (e.clo (HLL:ref #f v.clo)))
                      (set-hllvar-data! lhs e.clo)  ; all must reference closure before any fv*-slot
                      (partition lb* wk* (cons (vector lhs rhs fv* v.clo) nwk*)))))))))
    (define (Well-known-letrec bank note lb* body)
      ;; All procedures bound by this letrec can share the same closure.  That closure does not need
      ;; a code header, so it can use a simpler representation.
      (let* ((v.share (hllvar 'clo #f))
             (wk* (lb*-map (lambda (lhs rhs) (let ((fv* (hllvar-data lhs)))
                                               (known! lhs)
                                               (set-hllvar-data! lhs v.share)
                                               (make-wk lhs rhs fv*)))
                           lb*))
             (wk* (map wk-normalize wk*))
             (fv*.union (fv*-normalize (cons v.share (append* (map wk-fv* wk*)))))
             (len.fv* (length fv*.union)))
        (define (rebuild CL/fv*.X fv=>e deposit?)
          (let ((lb* (map (lambda (wk) (let-binding (wk-lhs wk)
                                                    (CL/fv*.X bank (wk-fv* wk) (wk-rhs wk))))
                          wk*)))
            (alist-for-each set-hllvar-data! fv=>e)
            (let ((bank (if deposit? (bank-deposit bank v.share fv*.union len.fv*) bank)))
              (HLL:letrec note lb* (Expr/bank bank body)))))
        (case len.fv*
          ((1) (for-each (lambda (wk) (set-hllvar-data! (wk-lhs wk) #f)) wk*)
               (HLL:letrec note (LB* (lambda (a p b) (cl-clause a p (Expr/bank bank.empty b))) lb*)
                           (Expr/bank bank body)))
          ((2) (let* ((fv* (cdr fv*.union))
                      (fv.single (car fv*)) (e.single (hllvar-data fv.single)))
                 (for-each (lambda (wk) (set-hllvar-data! (wk-lhs wk) fv.single)) wk*)
                 (set-hllvar-data! fv.single 0)
                 (let ((lb* (map (lambda (wk) (let-binding (wk-lhs wk)
                                                           (CL/fv*.single bank fv* (wk-rhs wk))))
                                 wk*)))
                   (set-hllvar-data! fv.single e.single)
                   (HLL:letrec note lb* (Expr/bank bank body)))))
          (else (let-values (((len.fv* fv=>e) (bank-find bank v.share fv*.union len.fv*)))
                  (if (eqv? len.fv* 3)
                      (if fv=>e
                          (rebuild CL/fv*.pair fv=>e #f)
                          (let-values (((i slot* fv=>e) (fv*-slot fv*.union)))
                            (HLL:let* #f (list (let-binding v.share (HLL:cons #f (cadr slot*)
                                                                              (car slot*))))
                                      (rebuild CL/fv*.pair fv=>e #t))))
                      (if fv=>e
                          (rebuild CL/fv*.vec fv=>e #f)
                          (let-values (((i slot* fv=>e) (fv*-slot fv*.union)))
                            (HLL:let* #f (list (let-binding v.share
                                                            (HLL:vector #f (cdr (reverse slot*)))))
                                      (rebuild CL/fv*.vec fv=>e #t))))))))))
    (define (No-free-variables-letrec bank note lb* body)
      ;; For each procedure bound by this letrec, if it is well-known it does not require a closure
      ;; at all, and if it is not-well-known then it needs a closure that only contains a
      ;; code-header, and the procedure body can ignore its closure parameter (i.e., it can be #f).
      (let loop ((lb* lb*) (wk* '()) (nwk* '()) (clo* '()) (init^ #f))
        (if (null? lb*)
            (let ((wk* (LB* (lambda (a p b) (cl-clause a p (Expr/bank bank.empty b))) wk*))
                  (nwk* (LB* (lambda (a p b)
                               (cl-clause (arity+ a 1) (cons #f p) (Expr/bank bank.empty b)))
                             nwk*))
                  (body (Expr/bank bank body)))
              (if (null? nwk*)
                  (HLL:letrec note wk* body)
                  (HLL:let* #f clo* (HLL:letrec note (append wk* nwk*) (HLL:begin #f init^ body)))))
            (let* ((lb (car lb*)) (lb* (cdr lb*)) (lhs (let-binding-lhs lb)))
              (if (well-known? lhs)
                  (begin (known! lhs) (set-hllvar-data! lhs #f)
                         (loop lb* (cons lb wk*) nwk* clo* init^))
                  (let* ((v.clo (hllvar 'clo #f)) (e.clo (HLL:ref #f v.clo)))
                    (set-hllvar-data! lhs e.clo)
                    (let ((clo (let-binding v.clo (HLL:make-closure #f (HLL:quote #f 1))))
                          (init (HLL:closure-set! #f e.clo (HLL:quote #f 0) (HLL:ref #f lhs))))
                      (loop lb* wk* (cons lb nwk*) (cons clo clo*)
                            (if init^ (cons init^ init) init)))))))))
    (define (Join-point-letrec bank note lb* body)
      (lb*-for-each (lambda (lhs _) (known! lhs) (set-hllvar-data! lhs #f)) lb*)
      (HLL:letrec note (LB* (lambda (a p b) (cl-clause a p (Expr/bank bank b))) lb*)
                  (Expr/bank bank body)))
    (define (Letrec bank note lb* body)
      (let* ((lb (car lb*)) (lhs (let-binding-lhs lb)) (fv* (hllvar-data lhs)))
        ;; Following HLL-stratify-letrec, if any fv*=(), then all fv*=()
        (cond ((eqv? fv* tag.join-point) (Join-point-letrec bank note lb* body))
              ((null? fv*) (No-free-variables-letrec bank note lb* body))
              ((andmap (lambda (lb) (well-known? (let-binding-lhs lb))) lb*)
               (Well-known-letrec bank note lb* body))
              (else (Not-well-known-letrec bank note lb* body)))))
    (define (Expr x) (Expr/bank bank x))
    (define note (HLL-note x))
    (HLL-case
      x
      ((ref v)             (HLL-annotate (var-ref v) note))
      ((prim-ref _)        x)
      ((quote _)           x)
      ((if c t f)          (HLL:if note (Expr c) (Expr t) (Expr f)))
      ((begin e^ e)        (HLL:begin note (tree-map Expr e^) (Expr e)))
      ((prim-call p rand*) (HLL:prim-call note p (map Expr rand*)))
      ((call rator rand*)
       (let ((rand* (map Expr rand*)))
         (let retry ((rator rator))
           (HLL-case
             rator
             ((ref v) (cond ((not (known? v)) (HLL:closure-call note (var-ref v) rand*))
                            ((hllvar-data v)  (HLL:call note rator (cons (var-ref v) rand*)))
                            (else             (HLL:call note rator rand*))))
             ((late &e) (retry (unbox &e)))
             (_         (HLL:closure-call note (Expr rator) rand*))))))
      ((letrec lb* body) (if (null? lb*) (Expr body) (Letrec bank note lb* body)))
      ((let* lb* body)
       (HLL:let* note (lb*-map (lambda (l r) (let-binding l (Expr r))) lb*) (Expr body)))
      ((apply/values rator rand) (HLL:apply/values note (Expr rator) (Expr rand)))
      ((case-values rand clc*)
       (HLL:case-values note (Expr rand) (clc*-map (lambda (a p b) (cl-clause a p (Expr b))) clc*)))
      ((late &e) (Expr (unbox &e)))))
  (let ((P (Expr/bank bank.empty P)))
    (alist-for-each (lambda (v _) (set-hllvar-data! v #f)) proc=>fv*)
    (alist-for-each set-hllvar-data2! v=>data2)
    P))
